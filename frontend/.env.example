# Backend URL used by Vite's dev proxy.
# In dev, the app calls `/api/*` and Vite forwards to this address.
VITE_DEV_BACKEND=http://127.0.0.1:8000

# Set this for production builds to override the API base URL.
# Leave unset to keep using the same-origin `/api` prefix.
# VITE_API_BASE=https://api.example.com
